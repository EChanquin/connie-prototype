# Connie backend (Langflow) connection.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys.
#
# These have NO "VITE_" prefix on purpose: they are read only by the Vite dev server
# (vite.config.ts), which proxies /langflow -> Langflow and injects the API key server-side.
# The browser never sees the key.

# Where your Langflow server is running.
LANGFLOW_URL=http://localhost:7860

# Langflow API key (required on Langflow 1.5+).
# Create one in Langflow: Settings -> Langflow API Keys -> Add New. Copy it immediately.
LANGFLOW_API_KEY=sk-replace-with-your-langflow-api-key
